<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_flower_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center_horizontal">

            <View android:layout_width="0dp" android:layout_height="60dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦"
                android:textSize="32sp"
                android:textColor="#C9A84C"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEMINAR APP"
                android:textSize="30sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/poppins_bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="6dp"/>

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="#C9A84C"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masuk untuk mendaftar seminar"
                android:textSize="13sp"
                android:textColor="#B0C4D8"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginBottom="48dp"/>

            <!-- Card dengan sedikit transparan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_glass_dark"
                android:orientation="vertical"
                android:padding="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Login"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Silakan login dengan akun Anda"
                    android:textSize="12sp"
                    android:textColor="#8FA8C0"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginBottom="24dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#C9A84C"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="contoh@gmail.com"
                    android:inputType="textEmailAddress"
                    android:padding="14dp"
                    android:background="@drawable/input_dark"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#5A7A95"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="14sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvEmailError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠ Email harus menggunakan @gmail.com"
                    android:textSize="11sp"
                    android:textColor="#FF6B6B"
                    android:fontFamily="@font/poppins_regular"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textColor="#C9A84C"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Masukkan password"
                    android:inputType="textPassword"
                    android:padding="14dp"
                    android:background="@drawable/input_dark"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#5A7A95"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="14sp"
                    android:layout_marginBottom="28dp"/>

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="MASUK"
                    android:textColor="#0A1628"
                    android:fontFamily="@font/poppins_semibold"
                    android:textSize="15sp"
                    android:letterSpacing="0.1"
                    android:background="@drawable/button_background"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>